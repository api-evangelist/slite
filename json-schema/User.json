{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/slite/main/json-schema/User.json",
  "title": "User",
  "properties": {
    "organizationRole": {
      "type": "string",
      "description": "Role of the user in the organization"
    },
    "isGuest": {
      "type": "boolean",
      "description": "Whether the user is a guest"
    },
    "archivedAt": {
      "type": "string",
      "format": "date-time",
      "nullable": true,
      "description": "Whether the user is archived"
    },
    "displayName": {
      "type": "string",
      "description": "Display name of the user"
    },
    "email": {
      "type": "string",
      "description": "Email address of the user"
    },
    "id": {
      "type": "string",
      "description": "User ID"
    }
  },
  "required": [
    "displayName",
    "email",
    "id"
  ],
  "type": "object"
}